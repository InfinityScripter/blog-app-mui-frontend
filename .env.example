# App
NEXT_PUBLIC_BASE_PATH=
NEXT_PUBLIC_SERVER_URL=http://localhost:7272
NEXT_PUBLIC_ASSET_URL=http://localhost:7272

# Personal-data collection master switch (UI side). Unset/false = registration
# page 404s, the sign-up link + OAuth buttons + newsletter forms are hidden, so
# the site collects NO personal data (152-ФЗ default). Set to 'true' to show the
# whole collection flow again. Must match the backend PD_COLLECTION_ENABLED.
# Sign-in of existing users is never gated.
NEXT_PUBLIC_PD_COLLECTION_ENABLED=false

# Search-engine ownership verification (paste token from each webmaster panel)
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
NEXT_PUBLIC_YANDEX_VERIFICATION=
NEXT_PUBLIC_BING_VERIFICATION=
