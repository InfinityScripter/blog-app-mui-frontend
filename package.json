{
  "name": "blog-app-mui-frontend",
  "author": "Mihail Talalaev",
  "version": "6.0.1",
  "description": "Blog & portfolio — Next.js + MUI frontend",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3033 --turbo",
    "start": "next start -p 3033",
    "build": "next build",
    "prepare": "husky",
    "export": "BUILD_STATIC_EXPORT=true next build",
    "lint": "eslint \"src/**/*.{js,jsx,ts,tsx}\"",
    "lint:fix": "eslint --fix \"src/**/*.{js,jsx,ts,tsx}\"",
    "fm:check": "prettier --check \"src/**/*.{js,jsx,ts,tsx}\"",
    "fm:fix": "prettier --write \"src/**/*.{js,jsx,ts,tsx}\"",
    "rm:all": "rm -rf node_modules .next out dist build",
    "re:start": "yarn rm:all && yarn install && yarn dev",
    "re:build": "yarn rm:all && yarn install && yarn build",
    "re:build-npm": "npm run rm:all && npm install && npm run build",
    "start:out": "npx serve@latest out -p 3033",
    "knip": "knip",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "llm-stats:push": "tsx scripts/push-llm-stats.ts",
    "analyze": "ANALYZE=true next build",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@emotion/cache": "^11.14.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@hookform/resolvers": "^5.2.1",
    "@iconify/react": "^6.0.0",
    "@mui/lab": "^7.0.0-beta.16",
    "@mui/material": "^7.3.1",
    "@mui/material-nextjs": "^7.3.0",
    "@mui/system": "7.3.5",
    "@mui/x-date-pickers": "^8.9.2",
    "@tiptap/core": "^3.0.9",
    "@tiptap/extension-code-block": "^3.0.9",
    "@tiptap/extension-code-block-lowlight": "^3.0.9",
    "@tiptap/extension-image": "^3.0.9",
    "@tiptap/extension-link": "^3.0.9",
    "@tiptap/extension-placeholder": "^3.0.9",
    "@tiptap/extension-text-align": "^3.0.9",
    "@tiptap/pm": "^3.0.9",
    "@tiptap/react": "^3.0.9",
    "@tiptap/starter-kit": "^3.0.9",
    "@vercel/analytics": "^1.5.0",
    "@vercel/speed-insights": "^2.0.0",
    "apexcharts": "^5.3.2",
    "autosuggest-highlight": "^3.3.4",
    "axios": "^1.11.0",
    "better-sqlite3": "^11.10.0",
    "critters": "^0.0.25",
    "dayjs": "^1.11.13",
    "framer-motion": "^12.23.12",
    "lowlight": "^3.3.0",
    "marked": "^18.0.5",
    "mui-one-time-password-input": "^5.0.0",
    "next": "^15.4.8",
    "nprogress": "^0.2.0",
    "react": "^19.1.1",
    "react-apexcharts": "^1.7.0",
    "react-dom": "^19.1.1",
    "react-dropzone": "^14.3.8",
    "react-hook-form": "^7.62.0",
    "react-lazy-load-image-component": "^1.6.3",
    "react-markdown": "^10.1.0",
    "react-phone-number-input": "^3.4.12",
    "rehype-highlight": "^7.0.2",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "simplebar-react": "^3.3.2",
    "sonner": "^2.0.7",
    "stylis": "^4.3.6",
    "stylis-plugin-rtl": "^2.1.1",
    "swr": "^2.3.4",
    "turndown": "^7.2.0",
    "zod": "^4.0.15"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.2.9",
    "@playwright/test": "^1.60.0",
    "@types/autosuggest-highlight": "^3.2.3",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.2.0",
    "@types/nprogress": "^0.2.3",
    "@types/react": "^19.1.9",
    "@types/turndown": "^5.0.6",
    "@typescript-eslint/eslint-plugin": "^8.48.0",
    "@typescript-eslint/parser": "^8.48.0",
    "depcheck": "^1.4.7",
    "eslint": "^8.57.1",
    "eslint-config-airbnb": "^19.0.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-alias": "^1.1.2",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-perfectionist": "^4.15.0",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-unused-imports": "^4.1.4",
    "husky": "^9.1.7",
    "knip": "^5.62.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.6.2",
    "tsx": "^4.22.4",
    "typescript": "^5.9.2",
    "vitest": "^2.1.9"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css,scss,mjs,cjs,yml,yaml}": "prettier --write"
  },
  "sideEffects": [
    "*.css",
    "*.scss",
    "./src/global.css"
  ],
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
